# ─── UNMASQUE Web — Environment Variables ──────────────────────
# Copy this file to .env and fill in your values
# Never commit .env to source control

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_BASE_URL=ws://localhost:8000/ws
VITE_APP_NAME=UNMASQUE Web

# Backend (FastAPI)
DATABASE_URL=postgresql://unmasque:secret@localhost:5432/unmasque_meta
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-me-to-a-random-64-char-secret-key
ENCRYPTION_KEY=change-me-to-a-random-32-char-aes-key

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email (SMTP) - use Gmail App Password for real Gmail delivery
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@unmasque.iisc.ac.in
EMAIL_FROM_NAME=UNMASQUE Web
# Ensure Gmail 2-Step Verification is enabled and use an App Password for EMAIL_PASS

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Job limits
MAX_CONCURRENT_JOBS_PER_USER=3
MAX_CONCURRENT_JOBS_SYSTEM=10
DEFAULT_SAMPLE_PERCENTAGE=2
DEFAULT_INVOCATION_TIMEOUT=300
DEFAULT_JOB_TIMEOUT_MINUTES=120

# PostgreSQL (metadata DB)
POSTGRES_USER=unmasque
POSTGRES_PASSWORD=secret
POSTGRES_DB=unmasque_meta
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# App
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
ENVIRONMENT=development
